---
import Base from "../layouts/Base.astro";
import Reveal from "../components/react/Reveal.jsx";
import Typed from "../components/react/Typed.jsx";
import TiltCard from "../components/react/TiltCard.jsx";
import { profile, skills, projects, contacts } from "../data/site.js";

const year = new Date().getFullYear();
---

<Base>
  <!-- ===== HERO ===== -->
  <section id="top" class="mx-auto flex min-h-screen max-w-5xl flex-col justify-center px-6 pt-24 pb-16">
    <Reveal client:load>
      <p class="mb-5 text-sm text-muted">
        <span class="text-accent">arnab@server</span>:~$ whoami
      </p>
      <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-tight text-white sm:text-6xl md:text-7xl">
        {profile.name}<span class="text-gradient">.</span>
      </h1>
      <div class="mt-5 text-lg md:text-xl">
        <Typed words={profile.roles} client:visible />
      </div>
      <p class="mt-6 max-w-xl text-[15px] leading-relaxed text-muted">
        {profile.lede}
      </p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a
          href="#projects"
          class="rounded-lg bg-accent px-5 py-3 text-sm font-bold text-bg transition-all hover:-translate-y-0.5 hover:shadow-glow"
        >
          ./view_projects
        </a>
        <a
          href="#contact"
          class="rounded-lg border border-line bg-surface px-5 py-3 text-sm text-text transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent"
        >
          ./get_in_touch
        </a>
      </div>
    </Reveal>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="mx-auto max-w-5xl border-t border-line px-6 py-20">
    <Reveal client:visible>
      <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">// about</p>
      <h2 class="mb-8 font-display text-2xl font-bold text-white md:text-3xl">cat about.json</h2>
      <div class="overflow-hidden rounded-xl border border-line bg-surface shadow-2xl shadow-black/40">
        <div class="flex items-center gap-2 border-b border-line bg-surface-2 px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-[#ff5f56]"></span>
          <span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="h-3 w-3 rounded-full bg-[#27c93f]"></span>
          <span class="ml-2 text-xs text-muted">~/arnab/about.json</span>
        </div>
        <pre class="overflow-x-auto p-6 text-[13.5px] leading-relaxed"><code><span class="text-accent">$ cat about.json</span>
{"{"}
  <span class="text-accent-3">"name"</span>: <span class="text-amber-400">"{profile.about.name}"</span>,
  <span class="text-accent-3">"role"</span>: <span class="text-amber-400">"{profile.about.role}"</span>,
  <span class="text-accent-3">"focus"</span>: [{profile.about.focus.map((f, i) => (<><span class="text-amber-400">"{f}"</span>{i < profile.about.focus.length - 1 ? ", " : ""}</>))}],
  <span class="text-accent-3">"philosophy"</span>: <span class="text-amber-400">"{profile.about.philosophy}"</span>,
  <span class="text-accent-3">"currently"</span>: <span class="text-amber-400">"{profile.about.currently}"</span>,
  <span class="text-accent-3">"open_to"</span>: <span class="text-amber-400">"{profile.about.open_to}"</span>
{"}"}
<span class="text-accent">$ <span class="caret">&nbsp;</span></span></code></pre>
      </div>
    </Reveal>
  </section>

  <!-- ===== SKILLS ===== -->
  <section id="skills" class="mx-auto max-w-5xl border-t border-line px-6 py-20">
    <Reveal client:visible>
      <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">// skills</p>
      <h2 class="mb-8 font-display text-2xl font-bold text-white md:text-3xl">tech stack</h2>
    </Reveal>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {skills.map((s, i) => (
        <Reveal delay={i * 0.06} className="h-full" client:visible>
          <div class="group flex h-full flex-col rounded-xl border border-line bg-surface/70 p-6 backdrop-blur-sm transition-all hover:-translate-y-1 hover:border-accent-2/60">
            <h3 class="mb-4 flex items-center gap-2.5 text-sm font-semibold text-accent-2">
              <span class="text-lg">{s.icon}</span> {s.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {s.tags.map((t) => (
                <span class="rounded-md border border-line bg-surface-2 px-3 py-1.5 text-xs text-muted transition-colors group-hover:text-text hover:!border-accent hover:!text-accent">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  <!-- ===== PROJECTS ===== -->
  <section id="projects" class="mx-auto max-w-5xl border-t border-line px-6 py-20">
    <Reveal client:visible>
      <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">// projects</p>
      <h2 class="mb-8 font-display text-2xl font-bold text-white md:text-3xl">ls -la ./projects</h2>
    </Reveal>
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {projects.map((p, i) => (
        <Reveal delay={i * 0.08} className="h-full" client:visible>
          <TiltCard className="h-full" client:visible>
            <div class="flex items-start justify-between gap-3">
              <h3 class="font-display text-lg font-semibold text-white">{p.name}</h3>
              <span class="text-sm font-bold text-faint">{p.num}</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-muted">{p.desc}</p>
            <div class="mt-auto pt-5">
              <div class="mb-4 flex flex-wrap gap-x-3 gap-y-1">
                {p.stack.map((t) => (
                  <span class="text-xs text-accent-3">{t}</span>
                ))}
              </div>
              <div class="flex gap-4">
                {p.live && (
                  <a
                    href={p.live}
                    target="_blank"
                    rel="noopener"
                    class="text-[13px] font-medium text-accent transition-colors hover:underline"
                  >
                    ↗ live
                  </a>
                )}
                {p.source && (
                  <a
                    href={p.source}
                    target="_blank"
                    rel="noopener"
                    class="text-[13px] text-accent-2 transition-colors hover:text-accent hover:underline"
                  >
                    ↗ source
                  </a>
                )}
              </div>
            </div>
          </TiltCard>
        </Reveal>
      ))}
    </div>
    <Reveal client:visible>
      <div class="mt-6 rounded-lg border border-dashed border-line bg-surface/50 px-4 py-3.5 text-[13px] text-muted">
        💡 Future-ready: separate projects can live on subdomains like
        <code class="text-accent">blog.arnabbiswas.in</code> or
        <code class="text-accent">api.arnabbiswas.in</code> and link back here.
      </div>
    </Reveal>
  </section>

  <!-- ===== CONTACT ===== -->
  <section id="contact" class="mx-auto max-w-5xl border-t border-line px-6 py-20">
    <Reveal client:visible>
      <p class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">// contact</p>
      <h2 class="mb-8 font-display text-2xl font-bold text-white md:text-3xl">curl -X POST /connect</h2>
    </Reveal>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {contacts.map((c, i) => (
        <Reveal delay={i * 0.05} client:visible>
          <a
            href={c.href}
            target={c.href.startsWith("mailto") ? undefined : "_blank"}
            rel="noopener"
            class="group flex items-center gap-4 rounded-xl border border-line bg-surface/70 px-5 py-4 backdrop-blur-sm transition-all hover:-translate-y-1 hover:border-accent"
          >
            <span class="text-2xl">{c.icon}</span>
            <span>
              <span class="block text-xs text-muted">{c.label}</span>
              <span class="block text-sm text-text transition-colors group-hover:text-accent">{c.value}</span>
            </span>
          </a>
        </Reveal>
      ))}
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="mx-auto max-w-5xl border-t border-line px-6 py-10 text-center">
    <p class="text-[13px] text-muted">
      <span class="text-accent">$</span> echo "Built with
      <svg viewBox="0 0 512 512" width="14" height="14" role="img" aria-label="Claude Code" fill="#d97757" fill-rule="evenodd" clip-rule="evenodd" style="vertical-align:-2px;display:inline-block">
        <path d="M447.957 233.579H512v66.176h-64v64.597h-31.723v62.315H384v-62.315h-31.723v62.315H320v-62.315H192v62.315h-32.256v-62.315H128v62.315H95.723v-62.315H64v-64.619H0V233.6h64V106.667h383.957v126.912zm-319.957 0h31.744v-60.736H128v60.736zm224.213 0H384v-60.736h-31.787v60.736z"></path>
      </svg>
      &amp; caffeine by Arnab Biswas · {year}"
    </p>
  </footer>
</Base>
